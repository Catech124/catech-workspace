#!/bin/bash
# ==============================================
# freebuff2-setup - Configura la cuenta #2
# Ejecutar SOLO UNA VEZ para iniciar sesión
# en la segunda cuenta de Freebuff
# ==============================================

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ACCOUNT_HOME="$HOME/.freebuff-account2"

echo "========================================="
echo "  Configurando cuenta #2 de Freebuff"
echo "========================================="
echo ""
echo "  Se abrira Freebuff con un HOME aislado."
echo "  Inicia sesion con tu SEGUNDA cuenta."
echo "  Al terminar, sal con Ctrl+C o /exit"
echo ""
echo "  HOME aislado: $ACCOUNT_HOME"
echo "========================================="
echo ""

# Usa freebuff2 directamente (evita duplicar logica)
exec "$SCRIPT_DIR/freebuff2"

# Si freebuff2 no existe, fallback inline
mkdir -p "$ACCOUNT_HOME/.config"
HOME="$ACCOUNT_HOME" freebuff

echo ""
echo "========================================="
echo "  Cuenta #2 configurada!"
echo "  Credenciales en: $ACCOUNT_HOME/.config/manicode/"
echo ""
echo "  Para usar la cuenta #2: freebuff2"
echo "  Para usar la cuenta #1: freebuff (normal)"
echo "========================================="
