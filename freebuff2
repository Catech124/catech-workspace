#!/bin/bash
# ==============================================
# freebuff2 - Ejecuta Freebuff con cuenta #2
# Usa un HOME aislado para no interferir con
# la cuenta principal (~/.config/manicode/).
# Usa el freebuff del sistema (PATH) con HOME aislado.
#
# NOTA: Antes usaba un binario custom compilado desde
# ~/freebuff-modified/ (que ya no existe). Se revirtió
# al freebuff del sistema para que funcione de nuevo.
# ==============================================

ACCOUNT_HOME="$HOME/.freebuff-account2"

command -v freebuff >/dev/null 2>&1 || {
    echo "[ERROR] freebuff no encontrado en PATH" >&2
    exit 1
}

mkdir -p "$ACCOUNT_HOME/.config"
HOME="$ACCOUNT_HOME" freebuff
