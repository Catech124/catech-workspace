#!/bin/bash
# ==============================================
# freebuff3-setup - Configura la cuenta #3
# Ejecutar SOLO UNA VEZ para iniciar sesión
# en la tercera cuenta de Freebuff
# ==============================================

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ACCOUNT_HOME="$HOME/.freebuff-account3"

echo "========================================="
echo "  Configurando cuenta #3 de Freebuff"
echo "========================================="
echo ""
echo "  Se abrira Freebuff con un HOME aislado."
echo "  Inicia sesion con tu TERCERA cuenta."
echo "  Al terminar, sal con Ctrl+C o /exit"
echo ""
echo "  HOME aislado: $ACCOUNT_HOME"
echo "========================================="
echo ""

exec "$SCRIPT_DIR/freebuff3"

mkdir -p "$ACCOUNT_HOME/.config"
HOME="$ACCOUNT_HOME" freebuff

echo ""
echo "========================================="
echo "  Cuenta #3 configurada!"
echo "  Credenciales en: $ACCOUNT_HOME/.config/manicode/"
echo ""
echo "  Para usar la cuenta #3: freebuff3"
echo "  Para usar la cuenta #2: freebuff2"
echo "  Para usar la cuenta #1: freebuff (normal)"
echo "========================================="
